# === MCP Provider 개발(dev) 환경 (.env.dev) ===
# 배포 시 after_install.sh 가 배포그룹명에 "dev" 포함 시 이 파일을 app/.env 로 복사.
# 브랜치: deploy/dev
# ※ 비밀값(CHANGE_ME)은 서버/SSM 에서 실제 값으로 채울 것. 저장소에 실제 비밀 커밋 금지.

# --- MCP 엔드포인트 인증(기계 클라이언트용 Bearer) ---
MCP_AUTH_TOKEN=Qtr61kzOvii5zMZCgzunAeBYk267t9cH4xe4E7PK3x1x4ca-R2y-vyLw-Oa2_qyj

# --- 노출 범위(비우면 노출된 모든 워크플로우) ---
MCP_GROUP=

# --- DNS rebinding 방어 (ALB 가 Host 헤더 보존) ---
MCP_ALLOWED_HOSTS=*.xperp.co.kr,localhost:*,127.0.0.1:*

# --- 대상 API 기본 base_url ---
MCP_DEFAULT_BASE_URL=https://devp-api.xperp.co.kr

# --- 포트 ---
MCP_PUBLIC_PORT=9900
UI_PUBLIC_PORT=9090

# --- 로깅 ---
LOG_LEVEL=DEBUG

# --- 관리 UI 로그인 (JWT) ---
APP_AUTH_USER=admin
APP_AUTH_PASSWORD=aegis7240@
APP_JWT_SECRET=6ba3450eddc17eef43468eeb92b99bc933a960cf851f68afd5b7152ac2fdb2fd
APP_JWT_EXPIRE_HOURS=24
APP_SESSION_IDLE_MINUTES=30
# ALB 가 HTTPS 종단이면 true
APP_COOKIE_SECURE=true
