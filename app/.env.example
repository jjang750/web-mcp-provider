# === MCP Provider 배포 환경변수 (.env 로 복사해 사용) ===
# 리버스 프록시가 TLS 종단 → 컨테이너는 HTTP.

# --- 인증 (도메인 노출 시 필수) ---
MCP_AUTH_TOKEN=change-me-to-a-long-random-token

# --- 관리 UI 로그인 (JWT, HttpOnly 쿠키 / 1일 만료) ---
# 아래 USER/PASSWORD 를 채우면 UI 인증이 활성화된다(비우면 무인증).
APP_AUTH_USER=admin
APP_AUTH_PASSWORD=change-me-strong-password
# JWT 서명 시크릿(긴 랜덤 문자열 필수). 예: openssl rand -hex 32
APP_JWT_SECRET=change-me-to-a-long-random-jwt-secret
# 절대 상한(시간). 기본 24 = 로그인 후 최대 하루.
APP_JWT_EXPIRE_HOURS=24
# 무활동 세션 타임아웃(분). 마지막 요청 후 이 시간 지나면 자동 로그아웃(요청마다 슬라이딩 갱신).
APP_SESSION_IDLE_MINUTES=30
# HTTPS(리버스 프록시 TLS 종단) 환경이면 true 권장. 로컬 HTTP 테스트는 false.
APP_COOKIE_SECURE=false

# --- 노출 범위 ---
# 특정 그룹만 노출하려면 지정(비우면 노출된 모든 워크플로우)
MCP_GROUP=xperp

# --- DNS rebinding 방어 (실도메인 지정 권장) ---
# 리버스 프록시가 Host 헤더를 보존해 전달해야 함(proxy_set_header Host $host)
MCP_ALLOWED_HOSTS=mcp.aegisep.com

# --- 대상 API 기본 base_url (스펙에 base_url 없을 때 폴백) ---
MCP_DEFAULT_BASE_URL=http://your-target-api:8000

# --- 호스트에 매핑할 포트 (리버스 프록시가 이 포트로 프록시) ---
MCP_PUBLIC_PORT=9900
UI_PUBLIC_PORT=9090

# --- 선택 ---
# MCP_JSON_RESPONSE=false
# --- DEBUG, INFO, WARNING, ERROR, CRITICAL ---
# LOG_LEVEL=INFO
